{
    "require": {
        "php": ">=8.2",
        "slim/slim": "4.*",
        "twig/twig": "3.*",
        "illuminate/database": "11.*",
        "ext-mysqli": "*",
        "ext-pdo": "*",
        "slim/psr7": "^1.8"
    },
    "autoload":{
        "psr-0":{
            "controller":"",
            "model":"",
            "db":"",
            "service":""
        },
        "psr-7":{
            "controller":"",
            "model":"",
            "db":"",
            "service":""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
